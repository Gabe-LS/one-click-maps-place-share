{
  "manifest_version": 3,
  "name": "One-Click Maps Place Share",
  "version": "1.0.1",
  "description": "Replaces the Google Maps share button: copies place name, location and short link to clipboard.",
  "permissions": ["clipboardWrite", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/maps*",
        "https://*.google.com/maps*"
      ],
      "js": ["interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://www.google.com/maps*",
        "https://*.google.com/maps*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
